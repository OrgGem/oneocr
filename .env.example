# Example environment configuration for OneOCR Docker deployment
# Copy this file to .env and adjust values as needed

# Wine Configuration
ONEOCR_WINE_MODE=1
WINEARCH=win64
WINEPREFIX=/root/.wine
DISPLAY=:0

# API Configuration
ONEOCR_PORT=8001
ONEOCR_HOST=0.0.0.0

# Logging
ONEOCR_LOG_LEVEL=INFO

# Resource Limits (for docker-compose)
ONEOCR_MEMORY_LIMIT=2g
ONEOCR_CPU_LIMIT=2

# Volume Configuration
ONEOCR_DLL_PATH=./oneocr_files
